{
  "name": "@rocicorp/lock",
  "version": "1.0.4",
  "description": "Implements Lock and RWLock synchronization primitives.",
  "license": "Apache-2.0",
  "repository": "github:rocicorp/lock",
  "files": [
    "out/*",
    "!out/*.test.*"
  ],
  "type": "module",
  "main": "./out/lock.js",
  "module": "./out/lock.js",
  "types": "out/lock.d.ts",
  "exports": {
    ".": "./out/lock.js"
  },
  "scripts": {
    "test": "vitest run src/",
    "fmt": "oxfmt",
    "format": "oxfmt",
    "check-format": "oxfmt --check",
    "lint": "eslint --ext .ts,.tsx,.js,.jsx src/",
    "build": "rm -rf out && tsc",
    "prepack": "pnpm run lint && pnpm run test"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^6.7.0",
    "@typescript-eslint/parser": "^6.7.0",
    "eslint": "^8.49.0",
    "oxfmt": "^0.51.0",
    "typescript": "^5.2.2",
    "vitest": "^4.1.6"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "packageManager": "pnpm@11.1.2"
}
