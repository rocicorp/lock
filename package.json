{
  "name": "@rocicorp/lock",
  "version": "1.0.4",
  "description": "Implements Lock and RWLock synchronization primitives.",
  "license": "Apache-2.0",
  "repository": "github:rocicorp/lock",
  "files": [
    "out/*",
    "!out/*.test.*"
  ],
  "type": "module",
  "main": "./out/lock.js",
  "module": "./out/lock.js",
  "types": "out/lock.d.ts",
  "exports": {
    ".": "./out/lock.js"
  },
  "scripts": {
    "test": "vitest run src/",
    "fmt": "oxfmt",
    "format": "oxfmt",
    "check-format": "oxfmt --check",
    "lint": "oxlint src/",
    "build": "rm -rf out && tsc",
    "prepack": "pnpm run lint && pnpm run test"
  },
  "devDependencies": {
    "oxfmt": "^0.51.0",
    "oxlint": "^1.66.0",
    "oxlint-tsgolint": "^0.23.0",
    "typescript": "^5.2.2",
    "vitest": "^4.1.6"
  },
  "engines": {
    "node": "^12.20.0 || ^14.13.1 || >=16.0.0"
  },
  "packageManager": "pnpm@11.1.2"
}
