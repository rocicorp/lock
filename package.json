{
  "name": "@rocicorp/lock",
  "version": "2.0.0",
  "description": "Implements Lock and RWLock synchronization primitives.",
  "license": "Apache-2.0",
  "repository": "github:rocicorp/lock",
  "files": [
    "out/*",
    "!out/*.test.*"
  ],
  "type": "module",
  "main": "./out/lock.js",
  "module": "./out/lock.js",
  "types": "out/lock.d.ts",
  "exports": {
    ".": "./out/lock.js"
  },
  "scripts": {
    "test": "vitest run src/",
    "fmt": "oxfmt",
    "format": "oxfmt",
    "check-format": "oxfmt --check",
    "check-types": "tsc",
    "check-types:watch": "tsc --watch",
    "lint": "oxlint src/",
    "build": "rm -rf out && tsc",
    "prepack": "pnpm run lint && pnpm run test"
  },
  "devDependencies": {
    "oxfmt": "^0.51.0",
    "oxlint": "^1.66.0",
    "oxlint-tsgolint": "^0.23.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "packageManager": "pnpm@11.2.2+sha512.36e6621fad506178936455e70247b8808ef4ec25797a9f437a93281a020484e2607f6a469a22e982987c3dbb8866e3071514ab10a4a1749e06edcd1ec118436f"
}
